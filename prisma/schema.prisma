generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  ADMIN
  MANAGER
  OPERATIONS_MANAGER
  ACCOUNTANT
  CUSTOMER
}

enum ShipmentStatus {
  CREATED
  WAITING
  SUBMITTED
  ACCEPTED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_WAREHOUSE
  PROCESSING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
  ON_HOLD
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  OVERDUE
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ShipmentCollectionType {
  PICKUP
  WAREHOUSE_DROP
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerProfile CustomerProfile?
  staffProfile    StaffProfile?

  createdShipments Shipment[] @relation("CreatedBy")
  auditLogs        AuditLog[]
}

model CustomerProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String?
  phone          String?
  taxId          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shipments      Shipment[]
  addresses      Address[]
  invoices       Invoice[]
  quotations     Quotation[]
}

model StaffProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     String?
  position       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Address {
  id                String          @id @default(cuid())
  customerProfileId String
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  label             String?         // e.g., "Home", "Warehouse"
  name              String          // Contact person
  phone             String?
  street1           String
  street2           String?
  city              String
  state             String?
  postalCode        String?
  countryId         String
  country           Country         @relation(fields: [countryId], references: [id])
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  pickupShipments   Shipment[]      @relation("PickupAddress")
  receiverShipments Shipment[]      @relation("ReceiverAddress")
}

model LogisticsCompany {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  shipments   Shipment[]
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique // ISO code e.g. "US", "IN"
  name      String
  isActive  Boolean  @default(true)
  displayOrder Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routesOrigin      Route[]   @relation("OriginCountry")
  routesDestination Route[]   @relation("DestinationCountry")
  addresses         Address[]
  shipments         Shipment[]
  warehouses        Warehouse[]

  @@index([isActive, displayOrder])
}

model Route {
  id                   String     @id @default(cuid())
  originCountryId      String
  originCountry        Country    @relation("OriginCountry", fields: [originCountryId], references: [id])
  destinationCountryId String
  destinationCountry   Country    @relation("DestinationCountry", fields: [destinationCountryId], references: [id])
  name                 String?
  serviceLevel         String?
  transitDays          Int?
  notes                String?
  isActive             Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  rateCards            RateCard[]
  shipments            Shipment[]

  @@index([isActive])
  @@index([originCountryId, destinationCountryId])
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  phone       String?
  street1     String
  street2     String?
  city        String
  state       String?
  postalCode  String?
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipments   Shipment[]

  @@index([countryId, isActive])
}

model RateCard {
  id        String   @id @default(cuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  weightMin Float
  weightMax Float
  basePrice Float
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shipment {
  id                  String         @id @default(cuid())
  trackingId          String         @unique
  awb                 String?        @unique
  referenceNo         String?
  pcs                 Int?
  collectionType      ShipmentCollectionType @default(PICKUP)
  
  customerId          String
  customer            CustomerProfile @relation(fields: [customerId], references: [id])

  countryId           String?
  country             Country?       @relation(fields: [countryId], references: [id])
  
  createdById         String?
  createdBy           User?          @relation("CreatedBy", fields: [createdById], references: [id])

  logisticsCompanyId  String?
  logisticsCompany    LogisticsCompany? @relation(fields: [logisticsCompanyId], references: [id])

  routeId             String?
  route               Route?          @relation(fields: [routeId], references: [id])

  warehouseId         String?
  warehouse           Warehouse?      @relation(fields: [warehouseId], references: [id])

  pickupAddressId     String?
  pickupAddress       Address?        @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  
  receiverAddressId   String?
  receiverAddress     Address?        @relation("ReceiverAddress", fields: [receiverAddressId], references: [id])
  receiverName        String?
  receiverPhone       String?

  pickupDate          DateTime?
  weight              Float?
  content             String?
  amount              Float?
  paymentStatus       PaymentStatus   @default(UNPAID)
  status              ShipmentStatus  @default(CREATED)
  rejectionReason     String?
  
  expectedArrivalDate DateTime?
  remarks             String?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  statusHistory       ShipmentStatusHistory[]
  events              ShipmentEvent[]
  invoice             Invoice?

  @@index([customerId])
  @@index([countryId])
  @@index([status])
  @@index([createdAt])
  @@index([trackingId])
  @@index([awb])
  @@index([referenceNo])
  @@index([customerId, status])
  @@index([createdAt, status])
  @@index([warehouseId])
}

model ShipmentStatusHistory {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      ShipmentStatus
  location    String?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([shipmentId])
  @@index([createdAt])
}

model ShipmentEvent {
  id          String    @id @default(cuid())
  shipmentId  String
  shipment    Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  title       String
  status      ShipmentStatus?
  location    String?
  note        String?   @map("description")
  createdAt   DateTime  @default(now())

  @@index([shipmentId])
  @@index([createdAt])
  @@index([status])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  shipmentId    String        @unique
  shipment      Shipment      @relation(fields: [shipmentId], references: [id])
  customerId    String
  customer      CustomerProfile @relation(fields: [customerId], references: [id])
  amount        Float
  dueDate       DateTime?
  status        PaymentStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId, status])
}

model Quotation {
  id           String          @id @default(cuid())
  quoteNumber  String          @unique
  customerId   String
  customer     CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  description  String?
  weight       Float?
  amount       Float?
  status       QuotationStatus @default(DRAFT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([customerId, status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}
