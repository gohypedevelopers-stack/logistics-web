generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                            String                  @id @default(cuid())
  email                         String                  @unique
  passwordHash                  String
  name                          String?
  role                          Role                    @default(CUSTOMER)
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  emailVerified                 Boolean                 @default(false)
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  emailVerificationLastSentAt   DateTime?
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  passwordResetLastSentAt       DateTime?
  auditLogs                     AuditLog[]
  customerProfile               CustomerProfile?
  createdShipments              Shipment[]              @relation("CreatedBy")
  ShipmentStatusHistory         ShipmentStatusHistory[]
  staffProfile                  StaffProfile?
}

model CustomerProfile {
  id                     String                          @id @default(cuid())
  userId                 String                          @unique
  companyName            String?
  phone                  String?
  taxId                  String?
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  addresses              Address[]
  user                   User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rateOverrides          CustomerRateOverride[]
  warehouseRateOverrides CustomerWarehouseRateOverride[]
  invoices               Invoice[]
  quotations             Quotation[]
  shipments              Shipment[]
}

model StaffProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  department String?
  position   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id                String          @id @default(cuid())
  customerProfileId String
  label             String?
  name              String
  phone             String?
  street1           String
  street2           String?
  city              String
  state             String?
  postalCode        String?
  countryId         String
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  country           Country         @relation(fields: [countryId], references: [id])
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  pickupShipments   Shipment[]      @relation("PickupAddress")
  receiverShipments Shipment[]      @relation("ReceiverAddress")
}

model LogisticsCompany {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  shipments   Shipment[]
}

model Country {
  id                String      @id @default(cuid())
  code              String      @unique
  name              String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  displayOrder      Int         @default(0)
  isActive          Boolean     @default(true)
  addresses         Address[]
  routesDestination Route[]     @relation("DestinationCountry")
  routesOrigin      Route[]     @relation("OriginCountry")
  shipments         Shipment[]
  warehouses        Warehouse[]

  @@index([isActive, displayOrder])
}

model Route {
  id                   String     @id @default(cuid())
  originCountryId      String
  destinationCountryId String
  isActive             Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  name                 String?
  notes                String?
  serviceLevel         String?
  transitDays          Int?
  rateCards            RateCard[]
  destinationCountry   Country    @relation("DestinationCountry", fields: [destinationCountryId], references: [id])
  originCountry        Country    @relation("OriginCountry", fields: [originCountryId], references: [id])
  shipments            Shipment[]

  @@index([isActive])
  @@index([originCountryId, destinationCountryId])
}

model Warehouse {
  id                    String                          @id @default(cuid())
  name                  String
  code                  String                          @unique
  phone                 String?
  street1               String
  street2               String?
  city                  String
  state                 String?
  postalCode            String?
  countryId             String
  isActive              Boolean                         @default(true)
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  customerRateOverrides CustomerWarehouseRateOverride[]
  shipments             Shipment[]
  country               Country                         @relation(fields: [countryId], references: [id])

  @@index([countryId, isActive])
}

model RateCard {
  id                String                 @id @default(cuid())
  routeId           String
  weightMin         Float
  weightMax         Float
  basePrice         Float
  currency          String                 @default("USD")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  customerOverrides CustomerRateOverride[]
  route             Route                  @relation(fields: [routeId], references: [id])
}

model CustomerRateOverride {
  id         String          @id @default(cuid())
  customerId String
  rateCardId String
  price      Float
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @default(now()) @updatedAt
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rateCard   RateCard        @relation(fields: [rateCardId], references: [id], onDelete: Cascade)

  @@unique([customerId, rateCardId])
  @@index([customerId])
  @@index([rateCardId])
}

model CustomerWarehouseRateOverride {
  id          String          @id @default(cuid())
  customerId  String
  warehouseId String
  price       Float
  currency    String          @default("USD")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  customer    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([customerId, warehouseId])
  @@index([customerId])
  @@index([warehouseId])
}

model Shipment {
  id                     String                  @id @default(cuid())
  trackingId             String                  @unique
  awb                    String                  @unique
  referenceNo            String?
  customerId             String
  createdById            String?
  logisticsCompanyId     String?
  routeId                String?
  pickupAddressId        String?
  receiverAddressId      String?
  weight                 Float?
  content                String?
  amount                 Float?
  paymentStatus          PaymentStatus           @default(UNPAID)
  status                 ShipmentStatus          @default(CREATED)
  rejectionReason        String?
  expectedArrivalDate    DateTime?
  remarks                String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  countryId              String?
  pcs                    Int?
  pickupDate             DateTime?
  receiverName           String?
  receiverPhone          String?
  collectionType         ShipmentCollectionType  @default(PICKUP)
  warehouseId            String?
  destinationAddressText String?
  destinationCountry     String?
  originCountry          String?
  pickupAddressText      String?
  invoice                Invoice?
  country                Country?                @relation(fields: [countryId], references: [id])
  createdBy              User?                   @relation("CreatedBy", fields: [createdById], references: [id])
  customer               CustomerProfile         @relation(fields: [customerId], references: [id])
  logisticsCompany       LogisticsCompany?       @relation(fields: [logisticsCompanyId], references: [id])
  pickupAddress          Address?                @relation("PickupAddress", fields: [pickupAddressId], references: [id])
  receiverAddress        Address?                @relation("ReceiverAddress", fields: [receiverAddressId], references: [id])
  route                  Route?                  @relation(fields: [routeId], references: [id])
  warehouse              Warehouse?              @relation(fields: [warehouseId], references: [id])
  events                 ShipmentEvent[]
  statusHistory          ShipmentStatusHistory[]

  @@index([customerId])
  @@index([countryId])
  @@index([status])
  @@index([createdAt])
  @@index([trackingId])
  @@index([awb])
  @@index([referenceNo])
  @@index([customerId, status])
  @@index([createdAt, status])
  @@index([warehouseId])
}

model ShipmentStatusHistory {
  id              String          @id @default(cuid())
  shipmentId      String
  status          ShipmentStatus
  location        String?
  notes           String?
  createdAt       DateTime        @default(now())
  changedByUserId String?
  oldStatus       ShipmentStatus?
  User            User?           @relation(fields: [changedByUserId], references: [id])
  shipment        Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([createdAt])
}

model ShipmentEvent {
  id         String          @id @default(cuid())
  shipmentId String
  title      String
  note       String?         @map("description")
  createdAt  DateTime        @default(now())
  location   String?
  status     ShipmentStatus?
  eventTime  DateTime        @default(now())
  shipment   Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([createdAt])
  @@index([status])
  @@index([eventTime])
}

model Invoice {
  id            String          @id @default(cuid())
  invoiceNumber String          @unique
  shipmentId    String          @unique
  customerId    String
  amount        Float
  dueDate       DateTime?
  status        PaymentStatus   @default(UNPAID)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      CustomerProfile @relation(fields: [customerId], references: [id])
  shipment      Shipment        @relation(fields: [shipmentId], references: [id])

  @@index([customerId, status])
}

model Quotation {
  id                 String          @id @default(cuid())
  quoteNumber        String          @unique
  customerId         String
  description        String?
  weight             Float?
  amount             Float?
  status             QuotationStatus @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  adminResponse      String?
  destinationCountry String?
  originCountry      String?
  pcs                Int?
  customer           CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, status])
  @@index([customerId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}

enum Role {
  CREATOR
  ADMIN
  MANAGER
  OPERATIONS_MANAGER
  ACCOUNTANT
  CUSTOMER
}

enum ShipmentStatus {
  CREATED
  WAITING
  ACCEPTED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_WAREHOUSE
  PROCESSING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  OVERDUE
}

enum QuotationStatus {
  PENDING
  RESPONDED
  APPROVED
  REJECTED
}

enum ShipmentCollectionType {
  PICKUP
  WAREHOUSE_DROP
}
